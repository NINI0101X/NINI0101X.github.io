                <div class="service-card">
                    <div class="service-icon">
                        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="24" cy="24" r="20" stroke="#003366" stroke-width="2"/>
                            <path d="M16 24H32M24 16V32" stroke="#FFB700" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <h3 class="service-title">Clases Individuales</h3>
                    <p class="service-description">Sesiones one-to-one diseñadas completamente a tu medida, con horarios flexibles y contenido adaptado a tus objetivos específicos.</p>
                    <div class="service-features">
                        <span class="feature-tag">60 minutos</span>
                        <span class="feature-tag">Online/Presencial</span>
                    </div>
                </div>

                <!-- Tarjeta 2 -->
                <div class="service-card">
                    <div class="service-icon">
                        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="16" cy="20" r="8" stroke="#003366" stroke-width="2"/>
                            <circle cx="32" cy="20" r="8" stroke="#003366" stroke-width="2"/>
                            <circle cx="24" cy="36" r="8" stroke="#003366" stroke-width="2"/>
                            <path d="M22 26L26 26" stroke="#FFB700" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <h3 class="service-title">Clases Grupales</h3>
                    <p class="service-description">Grupos pequeños (máximo 6 estudiantes) para aprender juntos, compartir experiencias y practicar en un ambiente colaborativo.</p>
                    <div class="service-features">
                        <span class="feature-tag">Hasta 6 personas</span>
                        <span class="feature-tag">90 minutos</span>
                    </div>
                </div>

                <!-- Tarjeta 3 -->
                <div class="service-card">
                    <div class="service-icon">
                        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="6" y="10" width="36" height="28" rx="2" stroke="#003366" stroke-width="2"/>
                            <path d="M6 18H42" stroke="#FFB700" stroke-width="2"/>
                            <circle cx="12" cy="14" r="1.5" fill="#003366"/>
                            <circle cx="18" cy="14" r="1.5" fill="#003366"/>
                            <circle cx="24" cy="14" r="1.5" fill="#003366"/>
                        </svg>
                    </div>
                    <h3 class="service-title">Preparación para Exámenes</h3>
                    <p class="service-description">Entrenamiento especializado para certificaciones internacionales como TOEFL, IELTS, Cambridge y otros exámenes de inglés.</p>
                    <div class="service-features">
                        <span class="feature-tag">Plan 12 semanas</span>
                        <span class="feature-tag">Garantizado</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN PORTAFOLIO -->
